# Copy this file to .env and keep .env local.
# Never commit real Slack, OpenAI, AI-VERDE, GitHub, or Tavily tokens.
# Rotate tokens immediately if they are exposed in git, screenshots, logs, or chat.

# --- Hermes runtime ----------------------------------------------------
DATA_ROOT=/data
DATA_DIR=./data
HERMES_STATE_DIR=~/.hermes
HERMES_RUNTIME_ROOT=/private/tmp
HERMES_CONTAINER_NAME=hermes-local
WORKSPACE_DIR=./workspace
WORKSPACE_UI_PORT=8888
WORKSPACE_UI_TOKEN=hermes
EXTERNAL_STORAGE_DIR=./external_storage
HERMES_RUNTIME_SECRETS_DIR=./secrets
HERMES_CMS_PORT=8090
HERMES_CONTAINER_CPUS=2.0
HERMES_CONTAINER_MEMORY=50g
HERMES_BRANDING=1
HERMES_PROJECT_TITLE=OASIS Hermes Workbench
HERMES_WORKER_IMAGE=hermes-spatiotemporal-worker:local
HERMES_WORKER_CPUS=2
HERMES_WORKER_MEMORY=4g
HERMES_K8S_NAMESPACE=hermes

# --- Hermes Agent and model routing -----------------------------------
HERMES_PORT=18789
HERMES_SEED_WORKSPACE=1
HERMES_INIT_WORKING_GROUP=1
HERMES_DASHBOARD_INSECURE=0
HERMES_DASHBOARD_BASIC_AUTH_USERNAME=
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD=
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD_HASH=
HERMES_DASHBOARD_OAUTH_CLIENT_ID=
HERMES_DASHBOARD_OIDC_ISSUER=
HERMES_DASHBOARD_OIDC_CLIENT_ID=
HERMES_DASHBOARD_OIDC_CLIENT_SECRET=
HERMES_MODEL_PROVIDER=custom
HERMES_INFERENCE_MODEL=js2/gpt-oss-120b

# Hermes Agent accepts OpenAI-compatible providers through these variables.
OPENAI_API_KEY=
OPENAI_API_KEY_FILE=
OPENAI_BASE_URL=

# Verde authorization can be provided directly or through a mounted secret file.
VERDE_LLM_API_KEY_FILE=
AI_VERDE_API_KEY_FILE=

# --- Slack PI Liaison -------------------------------------------------------
SLACK_BOT_TOKEN=xoxb-your-token
# Socket Mode app-level token. Create under Slack app settings > Basic Information > App-Level Tokens.
# It must start with xapp- and have the connections:write scope.
# Do not use the Slack signing secret or legacy verification token here.
SLACK_APP_TOKEN=xapp-1-APPID-INSTALLID-your-token
SLACK_DEFAULT_CHANNEL=#science-working-group

# --- AI-VERDE open-model experiments ---------------------------------------
# Keep real values local, and do not commit provider keys or endpoint secrets.
# Docs: https://aiverde-docs.cyverse.ai/api/
VERDE_LLM_BASE_URL=https://llm-api.cyverse.ai/v1
VERDE_LLM_API_KEY=
# Optional: choose a model from the current AI-VERDE inventory after confirming access.
VERDE_LLM_DEFAULT_MODEL=js2/gpt-oss-120b
VERDE_LLM_PROVIDER_NAME=verde

# Optional first-party or alternate provider keys.
NOUS_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# --- Optional external services -------------------------------------------
# GitHub integration and agent repo access.
# Prefer fine-grained, repository-scoped tokens for the target organization/repos.
# Do not commit real tokens. For Docker/Kubernetes secrets, set GITHUB_TOKEN_FILE
# to a mounted secret path such as /run/secrets/github_token instead of GITHUB_TOKEN.
# In GitHub Actions or Codespaces, store the value in GitHub Secrets and materialize
# it only into a runner-local secret file before starting Docker.
GITHUB_TOKEN=
GITHUB_TOKEN_FILE=
HERMES_CONFIGURE_GITHUB=1
TAVILY_API_KEY=

# --- Optional external storage providers -----------------------------------
# Keep real credentials local. The default demo paths do not require secrets.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
S3_ENDPOINT_URL=
WEBDAV_USER=
WEBDAV_PASSWORD=
IRODS_HOST=
IRODS_PORT=
IRODS_ZONE=
IRODS_USER_NAME=
IRODS_PASSWORD=
IRODS_DEFAULT_RESOURCE=
